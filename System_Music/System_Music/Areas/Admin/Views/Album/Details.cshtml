@using System_Music.Models.DTOs
@model AlbumDto

@{
    ViewData["Title"] = "Album Details";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Album Details</h1>

<div class="row">
    <div class="col-md-4 text-center">
        <div class="card shadow-sm mb-4">
            <img src="@Model.ImageUrl" alt="@Model.Name" class="card-img-top" style="object-fit: cover; aspect-ratio: 1/1;" onerror="this.src='/images/default-album.png'" />
            <div class="card-body">
                <h5 class="card-title">@Model.Name</h5>
                <p class="card-text text-muted">@Model.Artists.Select(a => a.Name).FirstOrDefault()</p>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Release Date</dt>
                    <dd class="col-sm-8">@(Model.ReleaseDate?.ToShortDateString() ?? "N/A")</dd>

                    <dt class="col-sm-4">Artists</dt>
                    <dd class="col-sm-8">@(string.Join(", ", Model.Artists.Select(a => a.Name)))</dd>

                    <dt class="col-sm-4">Zing ID</dt>
                    <dd class="col-sm-8">@Model.ZingMp3AlbumId</dd>

                    <dt class="col-sm-4">Tracks Count</dt>
                    <dd class="col-sm-8">@Model.Tracks.Count</dd>
                </dl>
            </div>
        </div>

        <div class="card shadow-sm mt-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">Tracks in this Album</h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var track in Model.Tracks)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-music me-2 text-primary"></i>
                                @track.Title
                            </div>
                            <span class="badge bg-secondary">@track.Duration</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="mt-4 pb-5">
    <a asp-action="Edit" asp-route-id="@Model.AlbumId" class="btn btn-warning px-4">Edit</a>
    <a asp-action="Index" class="btn btn-secondary px-4">Back to List</a>
</div>