@using System_Music.Models.DTOs
@model AlbumDto

@{
    ViewData["Title"] = "Tạo album mới";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row mt-4">
    <div class="col-md-8 mx-auto">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h3 class="card-title mb-0">Tạo album mới</h3>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-3">
                        <label asp-for="Name" class="form-label font-weight-bold">Tên Album</label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên album..." />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="ReleaseDate" class="form-label font-weight-bold">Ngày Phát Hành</label>
                        <input asp-for="ReleaseDate" class="form-control" type="date" />
                        <span asp-validation-for="ReleaseDate" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label font-weight-bold">Ảnh bìa</label>
                        <input type="file" name="imageFile" class="form-control" id="albumImage" />
                        <div id="imagePreview" class="mt-2 text-center" style="display:none;">
                             <img src="#" alt="Preview" style="max-width: 150px; border-radius: 8px;" />
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label font-weight-bold d-block">Nghệ sĩ tham gia</label>
                        <div class="border rounded p-3 bg-light" style="max-height: 200px; overflow-y: auto;">
                            @if (ViewBag.Artists != null)
                            {
                                @foreach (var artist in (IEnumerable<ArtistDto>)ViewBag.Artists)
                                {
                                    <div class="form-check">
                                        <input type="checkbox" name="artistIds" value="@artist.ArtistId" class="form-check-input" id="artist_@artist.ArtistId" />
                                        <label class="form-check-label" for="artist_@artist.ArtistId">@artist.Name</label>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label font-weight-bold">Bài hát thuộc album</label>
                        <select name="trackIds" multiple class="form-control select2" style="height: 200px;">
                            @if (ViewBag.Tracks != null)
                            {
                                @foreach (var track in (IEnumerable<TrackDto>)ViewBag.Tracks)
                                {
                                    <option value="@track.TrackId">@track.Title</option>
                                }
                            }
                        </select>
                        <small class="text-muted">Nhấn giữ Ctrl để chọn nhiều bài hát</small>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                        <button type="submit" class="btn btn-primary px-4">Tạo mới</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.getElementById('albumImage').addEventListener('change', function(e) {
            const preview = document.getElementById('imagePreview');
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(event) {
                    preview.style.display = 'block';
                    preview.querySelector('img').src = event.target.result;
                }
                reader.readAsDataURL(file);
            }
        });
    </script>
}