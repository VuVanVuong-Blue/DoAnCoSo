@using System_Music.Models.DTOs
@model IEnumerable<AlbumDto>

@{
    ViewData["Title"] = "Sync Albums from Zing MP3";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Sync Albums from Zing MP3</h1>

<div class="card mb-4 shadow-sm">
    <div class="card-body bg-light">
        <form asp-action="SyncFromZingMp3" method="get">
            <div class="row align-items-end">
                <div class="col-md-8">
                    <div class="form-group mb-0">
                        <label for="albumEncodeId" class="form-label font-weight-bold">Album Encode ID (e.g., 6BZO0I0O)</label>
                        <input type="text" id="albumEncodeId" name="albumEncodeId" class="form-control" value="@ViewData["AlbumEncodeId"]" placeholder="Enter Zing MP3 album encode ID..." />
                    </div>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">Sync Album</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger shadow-sm">
         <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success shadow-sm">
        <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
    </div>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info shadow-sm text-center py-4">
        <i class="fas fa-info-circle fa-2x mb-3 d-block text-secondary"></i>
        Enter an Album Encode ID and click "Sync" to fetch data from Zing MP3.
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Cover</th>
                    <th>Album Name</th>
                    <th>Artists</th>
                    <th>Tracks</th>
                    <th>Release Date</th>
                    <th>Zing ID</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var album in Model)
                {
                    <tr>
                        <td class="align-middle">
                            <img src="@album.ImageUrl" alt="@album.Name" style="width: 60px; height: 60px; object-fit: cover; border-radius: 4px;" onerror="this.src='/images/default-album.png'" />
                        </td>
                        <td class="align-middle font-weight-bold">@album.Name</td>
                        <td class="align-middle">
                            @(string.Join(", ", album.Artists.Select(a => a.Name)))
                        </td>
                        <td class="align-middle text-center">
                            <span class="badge bg-primary rounded-pill">@album.Tracks.Count</span>
                        </td>
                        <td class="align-middle text-nowrap">@(album.ReleaseDate?.ToShortDateString() ?? "N/A")</td>
                        <td class="align-middle text-muted small">@album.ZingMp3AlbumId</td>
                        <td class="align-middle text-nowrap">
                            <a asp-action="Details" asp-route-id="@album.AlbumId" class="btn btn-info btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@album.AlbumId" class="btn btn-warning btn-sm">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-4 pb-5">
    <a asp-action="Index" class="btn btn-secondary shadow-sm">Back to Albums List</a>
    <a asp-controller="Track" asp-action="SyncFromZingMp3" class="btn btn-outline-info shadow-sm">Sync Tracks from Zing MP3</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $('form').on('submit', function (e) {
                var albumEncodeId = $('#albumEncodeId').val().trim();
                if (!albumEncodeId) {
                    e.preventDefault();
                    alert('Please enter an Album Encode ID.');
                }
            });
        });
    </script>
}