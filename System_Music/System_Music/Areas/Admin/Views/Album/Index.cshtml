@using System_Music.Models.DTOs
@model IEnumerable<AlbumDto>

@{
    ViewData["Title"] = "Manage Albums";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Manage Albums</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Album</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Cover</th>
            <th>Name</th>
            <th>Artists</th>
            <th>Zing ID</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var album in Model)
        {
            <tr>
                <td>
                    <img src="@album.ImageUrl" alt="@album.Name" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;" onerror="this.src='/images/default-album.png'" />
                </td>
                <td>@album.Name</td>
                <td>
                    @(string.Join(", ", album.Artists.Select(a => a.Name)))
                </td>
                <td>@album.ZingMp3AlbumId</td>
                <td>
                    <a asp-action="Details" asp-route-id="@album.AlbumId" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@album.AlbumId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@album.AlbumId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>