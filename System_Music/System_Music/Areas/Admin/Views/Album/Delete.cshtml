@using System_Music.Models.DTOs
@model AlbumDto

@{
    ViewData["Title"] = "Delete Album";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Delete Album</h1>

<h3 class="text-danger mt-4">Are you sure you want to delete this album?</h3>
<div class="row mt-4">
    <div class="col-md-4 text-center">
        <div class="card shadow-sm">
            <img src="@Model.ImageUrl" alt="@Model.Name" class="card-img-top" style="object-fit: cover; aspect-ratio: 1/1;" onerror="this.src='/images/default-album.png'" />
        </div>
    </div>
    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-4">Album ID</dt>
            <dd class="col-sm-8">@Model.AlbumId</dd>

            <dt class="col-sm-4">Album Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Release Date</dt>
            <dd class="col-sm-8">@(Model.ReleaseDate?.ToShortDateString() ?? "N/A")</dd>

            <dt class="col-sm-4">Artists</dt>
            <dd class="col-sm-8">@(string.Join(", ", Model.Artists.Select(a => a.Name)))</dd>

            <dt class="col-sm-4">Zing ID</dt>
            <dd class="col-sm-8">@Model.ZingMp3AlbumId</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-4">
    <input type="hidden" asp-for="AlbumId" />
    <input type="submit" value="Delete" class="btn btn-danger px-4" />
    <a asp-action="Index" class="btn btn-secondary px-4">Back to List</a>
</form>