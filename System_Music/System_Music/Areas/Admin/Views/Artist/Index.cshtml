@using System_Music.Models.DTOs
@model IEnumerable<ArtistDto>

@{
    ViewData["Title"] = "Manage Artists";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Manage Artists</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Artist</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Country</th>
            <th>Zing ID</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var artist in Model)
        {
            <tr>
                <td>
                    <img src="@artist.ImageUrl" alt="@artist.Name" style="width: 50px; height: 50px; object-fit: cover; border-radius: 50%;" onerror="this.src='/images/default-artist.png'" />
                </td>
                <td>@artist.Name</td>
                <td>@artist.Country</td>
                <td>@artist.ZingMp3ArtistId</td>
                <td>
                    <a asp-action="Details" asp-route-id="@artist.ArtistId" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@artist.ArtistId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@artist.ArtistId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>