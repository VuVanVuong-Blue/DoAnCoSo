@using System_Music.Models.DTOs
@model IEnumerable<ArtistDto>

@{
    ViewData["Title"] = "Sync Artists from Zing MP3";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Sync Artists from Zing MP3</h1>

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="SyncFromZingMp3" method="get">
            <div class="row">
                <div class="col-md-5">
                    <div class="form-group mb-3">
                        <label for="artistName" class="form-label">Artist Name (e.g., NewJeans)</label>
                        <input type="text" id="artistName" name="artistName" class="form-control" value="@ViewData["ArtistName"]" placeholder="Enter artist name..." />
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="form-group mb-3">
                        <label for="artistId" class="form-label">Zing ID (e.g., IW6ZZ690)</label>
                        <input type="text" id="artistId" name="artistId" class="form-control" value="@ViewData["ArtistId"]" placeholder="Enter Zing artist ID..." />
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end mb-3">
                    <button type="submit" class="btn btn-primary w-100">Sync Artist</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">
        No artists found for the provided search criteria.
    </div>
}
else
{
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Country</th>
                <th>Image</th>
                <th>Zing Artist ID</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var artist in Model)
            {
                <tr>
                    <td>@artist.ArtistId</td>
                    <td>@artist.Name</td>
                    <td>@artist.Country</td>
                    <td>
                        <img src="@artist.ImageUrl" alt="@artist.Name" style="width: 50px; height: 50px; object-fit: cover; border-radius: 50%;" onerror="this.src='/images/default-artist.png'" />
                    </td>
                    <td>@artist.ZingMp3ArtistId</td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to Artists List</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $('form').on('submit', function (e) {
                var artistName = $('#artistName').val().trim();
                var artistId = $('#artistId').val().trim();
                if (!artistName && !artistId) {
                    e.preventDefault();
                    alert('Please enter either an Artist Name or an Artist ID.');
                }
            });
        });
    </script>
}