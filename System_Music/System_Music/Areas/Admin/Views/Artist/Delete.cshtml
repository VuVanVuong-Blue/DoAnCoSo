@using System_Music.Models.DTOs
@model ArtistDto

@{
    ViewData["Title"] = "Delete Artist";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Delete Artist</h1>

<h3>Are you sure you want to delete this artist?</h3>
<div>
    <hr />
    <div class="row">
        <div class="col-md-4 text-center">
            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded-circle mb-3" style="max-width: 150px; border: 4px solid #fff; box-shadow: 0 0 10px rgba(0,0,0,0.1);" onerror="this.src='/images/default-artist.png'" />
            <h3>@Model.Name</h3>
        </div>
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Artist ID</dt>
                <dd class="col-sm-9">@Model.ArtistId</dd>

                <dt class="col-sm-3">Zing ID</dt>
                <dd class="col-sm-9">@Model.ZingMp3ArtistId</dd>

                <dt class="col-sm-3">Country</dt>
                <dd class="col-sm-9">@Model.Country</dd>
            </dl>
        </div>
    </div>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="ArtistId" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>