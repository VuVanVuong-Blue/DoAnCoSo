@using System_Music.Models.DTOs
@model ArtistDto

@{
    ViewData["Title"] = "Artist Details";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Artist Details</h1>

<div>
    <hr />
    <div class="row">
        <div class="col-md-4 text-center">
            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded-circle mb-3" style="max-width: 250px; border: 4px solid #fff; box-shadow: 0 0 10px rgba(0,0,0,0.1);" onerror="this.src='/images/default-artist.png'" />
            <h3>@Model.Name</h3>
            <p class="text-muted">@Model.Country</p>
        </div>
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-3">Artist ID</dt>
                <dd class="col-sm-9">@Model.ArtistId</dd>

                <dt class="col-sm-3">Zing ID</dt>
                <dd class="col-sm-9">@Model.ZingMp3ArtistId</dd>

                <dt class="col-sm-3">Birth Date</dt>
                <dd class="col-sm-9">@(Model.BirthDate?.ToShortDateString() ?? "N/A")</dd>

                <dt class="col-sm-3">Active Status</dt>
                <dd class="col-sm-9">@(Model.IsActive ? "Active" : "Inactive")</dd>

                <dt class="col-sm-3">Play Count</dt>
                <dd class="col-sm-9">@Model.PlayCount</dd>

                <dt class="col-sm-12 mt-3">Biography</dt>
                <dd class="col-sm-12">@Html.Raw(Model.Biography?.Replace("\n", "<br/>") ?? "No biography available.")</dd>
            </dl>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model.ArtistId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>