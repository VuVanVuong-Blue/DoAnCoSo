@using System_Music.Models.DTOs
@model TrackDto

@{
    ViewData["Title"] = "Chỉnh sửa bài hát";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row mt-4">
    <div class="col-md-10 mx-auto">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">
                <h3 class="card-title mb-0 text-dark">Chỉnh sửa bài hát: @Model.Title</h3>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="TrackId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Title" class="form-label font-weight-bold">Tên bài hát</label>
                                <input asp-for="Title" class="form-control" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Duration" class="form-label font-weight-bold">Thời lượng (giây)</label>
                                <input asp-for="Duration" class="form-control" type="number" />
                                <span asp-validation-for="Duration" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="AlbumId" class="form-label font-weight-bold">Album</label>
                                <select asp-for="AlbumId" class="form-select">
                                    <option value="">-- Single (Không thuộc album) --</option>
                                    @foreach (var album in (IEnumerable<AlbumDto>)ViewBag.Albums)
                                    {
                                        <option value="@album.AlbumId" selected="@(album.AlbumId == Model.AlbumId ? "selected" : null)">@album.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label font-weight-bold">File nhạc mới</label>
                                <input type="file" name="audioFile" class="form-control" accept="audio/*" />
                                <small class="text-muted d-block mt-1">
                                    <i class="fas fa-file-audio me-1"></i> Current: @Model.AudioUrl
                                </small>
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label font-weight-bold">Ảnh bìa mới</label>
                                <input type="file" name="imageFile" class="form-control" accept="image/*" />
                                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <div class="mt-2 text-center">
                                        <img src="@Model.ImageUrl" alt="@Model.Title" style="max-width: 120px; border-radius: 8px;" onerror="this.src='/images/default-track.png'" />
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label class="form-label font-weight-bold">Nghệ sĩ tham gia</label>
                                <div class="border rounded p-3 bg-light" style="max-height: 180px; overflow-y: auto;">
                                    @foreach (var artist in (IEnumerable<ArtistDto>)ViewBag.Artists)
                                    {
                                        var isChecked = Model.Artists != null && Model.Artists.Any(a => a.ArtistId == artist.ArtistId);
                                        <div class="form-check">
                                            <input type="checkbox" name="artistIds" value="@artist.ArtistId" class="form-check-input" id="artist_@artist.ArtistId" @(isChecked ? "checked" : "") />
                                            <label class="form-check-label" for="artist_@artist.ArtistId">@artist.Name</label>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="form-group mb-3">
                                <label class="form-label font-weight-bold">Thể loại</label>
                                <div class="border rounded p-3 bg-light" style="max-height: 180px; overflow-y: auto;">
                                    @foreach (var genre in (IEnumerable<GenreDto>)ViewBag.Genres)
                                    {
                                        var isChecked = Model.Genres != null && Model.Genres.Any(g => g.GenreId == genre.GenreId);
                                        <div class="form-check">
                                            <input type="checkbox" name="genreIds" value="@genre.GenreId" class="form-check-input" id="genre_@genre.GenreId" @(isChecked ? "checked" : "") />
                                            <label class="form-check-label" for="genre_@genre.GenreId">@genre.Name</label>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="ZingMp3TrackId" class="form-label font-weight-bold">Zing MP3 Encode ID</label>
                                <input asp-for="ZingMp3TrackId" class="form-control" />
                                <span asp-validation-for="ZingMp3TrackId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Description" class="form-label font-weight-bold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                        <button type="submit" class="btn btn-warning px-5">Cập nhật</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}