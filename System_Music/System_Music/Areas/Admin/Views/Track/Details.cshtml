@using System_Music.Models.DTOs
@model TrackDto

@{
    ViewData["Title"] = "Track Details";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Track Details</h1>

<div class="row">
    <div class="col-md-4 text-center">
        <div class="card shadow-sm mb-4">
            <img src="@Model.ImageUrl" alt="@Model.Title" class="card-img-top" style="object-fit: cover; aspect-ratio: 1/1;" onerror="this.src='/images/default-track.png'" />
            <div class="card-body">
                <h5 class="card-title">@Model.Title</h5>
                <p class="card-text text-muted">@Model.AlbumName</p>
                @if (!string.IsNullOrEmpty(Model.AudioUrl))
                {
                    <audio controls class="w-100 mt-2">
                        <source src="@Model.AudioUrl" type="audio/mpeg">
                        Your browser does not support the audio element.
                    </audio>
                }
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Track ID</dt>
                    <dd class="col-sm-8">@Model.TrackId</dd>

                    <dt class="col-sm-4">Duration</dt>
                    <dd class="col-sm-8">@Model.Duration sec</dd>

                    <dt class="col-sm-4">Album</dt>
                    <dd class="col-sm-8">@(Model.AlbumName ?? "Single")</dd>

                    <dt class="col-sm-4">Artists</dt>
                    <dd class="col-sm-8">@(string.Join(", ", Model.Artists.Select(a => a.Name)))</dd>

                    <dt class="col-sm-4">Genres</dt>
                    <dd class="col-sm-8">@(string.Join(", ", Model.Genres.Select(g => g.Name)))</dd>

                    <dt class="col-sm-4">Zing ID</dt>
                    <dd class="col-sm-8">@(Model.ZingMp3TrackId ?? "N/A")</dd>

                    <dt class="col-sm-4">Play Count</dt>
                    <dd class="col-sm-8">@Model.PlayCount</dd>

                    <dt class="col-sm-4">Like Count</dt>
                    <dd class="col-sm-8">@Model.LikeCount</dd>

                    <dt class="col-sm-4">Added Date</dt>
                    <dd class="col-sm-8">@Model.AddedDate.ToString("f")</dd>
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Description</h5>
                </div>
                <div class="card-body">
                    <p>@Model.Description</p>
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-4 pb-5">
    <a asp-action="Edit" asp-route-id="@Model.TrackId" class="btn btn-warning px-4">Edit</a>
    <a asp-action="Index" class="btn btn-secondary px-4">Back to List</a>
</div>