@using System_Music.Models.DTOs
@model IEnumerable<TrackDto>

@{
    ViewData["Title"] = "Sync Tracks from Zing MP3";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Sync Tracks from Zing MP3</h1>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-primary text-white">Sync Single Track</div>
            <div class="card-body">
                <form asp-action="SyncFromZingMp3" method="get">
                    <div class="form-group mb-3">
                        <label for="encodeId" class="form-label">Track Encode ID (e.g., Z6BOBWWZ)</label>
                        <input type="text" id="encodeId" name="encodeId" class="form-control" value="@ViewData["EncodeId"]" placeholder="Enter track encode ID..." />
                    </div>
                    <button type="submit" class="btn btn-primary">Sync Track</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-success text-white">Sync Artist Songs</div>
            <div class="card-body">
                <form asp-action="SyncArtistSongsFromZingMp3" method="get">
                    <div class="form-group mb-3">
                        <label for="artistId" class="form-label">Artist ID (e.g., IW76C8FU)</label>
                        <input type="text" id="artistId" name="artistId" class="form-control" placeholder="Enter Artist ID..." />
                    </div>
                    <button type="submit" class="btn btn-success">Sync Artist Songs</button>
                </form>
            </div>
        </div>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info text-center py-4">
        No tracks synced yet. Use the forms above to fetch data.
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Cover</th>
                    <th>Title</th>
                    <th>Album</th>
                    <th>Artists</th>
                    <th>Duration</th>
                    <th>Zing ID</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var track in Model)
                {
                    <tr>
                        <td>
                            <img src="@track.ImageUrl" alt="@track.Title" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;" onerror="this.src='/images/default-track.png'" />
                        </td>
                        <td class="font-weight-bold">@track.Title</td>
                        <td>@(track.AlbumName ?? "Single")</td>
                        <td>@(string.Join(", ", track.Artists.Select(a => a.Name)))</td>
                        <td>@track.Duration</td>
                        <td class="small text-muted">@track.ZingMp3TrackId</td>
                        <td class="text-nowrap">
                            <a asp-action="Details" asp-route-id="@track.TrackId" class="btn btn-info btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@track.TrackId" class="btn btn-warning btn-sm">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-4 pb-5">
    <a asp-action="Index" class="btn btn-secondary">Back to Tracks List</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}