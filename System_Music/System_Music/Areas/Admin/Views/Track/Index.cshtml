@using System_Music.Models.DTOs
@model IEnumerable<TrackDto>

@{
    ViewData["Title"] = "Manage Tracks";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Manage Tracks</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Track</a>
</p>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Image</th>
                <th>Title</th>
                <th>Album</th>
                <th>Artists</th>
                <th>Duration</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var track in Model)
            {
                <tr>
                    <td>
                        <img src="@track.ImageUrl" alt="@track.Title" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px;" onerror="this.src='/images/default-track.png'" />
                    </td>
                    <td>@track.Title</td>
                    <td>@(track.AlbumName ?? "Single")</td>
                    <td>
                        @(string.Join(", ", track.Artists.Select(a => a.Name)))
                    </td>
                    <td>@track.Duration</td>
                    <td class="text-nowrap">
                        <a asp-action="Details" asp-route-id="@track.TrackId" class="btn btn-info btn-sm">Details</a>
                        <a asp-action="Edit" asp-route-id="@track.TrackId" class="btn btn-warning btn-sm">Edit</a>
                        <form asp-action="Delete" asp-route-id="@track.TrackId" method="post" style="display:inline;" onsubmit="return confirm('Are you sure?');">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>